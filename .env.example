# --- Backend ---
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
# Default per assignment; you can override if needed
GROQ_MODEL=gemma2-9b-it
# Optional fallback model if the primary model errors
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Example Postgres URL (matches docker-compose below)
DATABASE_URL=postgresql+psycopg://logai:logai@localhost:5432/logai

# Frontend dev server origin for CORS 
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend ---
# Vite exposes env vars prefixed with VITE_
VITE_API_BASE_URL=http://localhost:8000
